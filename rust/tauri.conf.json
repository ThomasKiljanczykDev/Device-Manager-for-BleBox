{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "device-manager-for-blebox",
  "version": "0.1.0",
  "identifier": "dev.kiljanczyk.blebox-device-manager",
  "build": {
    "frontendDist": "../js/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "yarn --cwd js dev",
    "beforeBuildCommand": "yarn --cwd js build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Device Manager for BleBox",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
