# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp.*

# Yarn (keep releases/plugins/sdks/versions)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# build output
dist/
build/
.vite/
.turbo/

# logs & caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
.cache/
coverage/
.nyc_output/

# OpenAPI generator runtime cache
.openapi-generator/
.openapi-generator-cli/

# env (keep .env.example)
.env
.env.local
.env.*.local

# OS / editor noise
.DS_Store
Thumbs.db
.idea/**
!.idea/prettier.xml
!.idea/jsLinters/eslint.xml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.ai/
