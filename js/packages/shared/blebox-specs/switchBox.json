{
  "openapi": "3.0.3",
  "info": {
    "title": "API Type: switchBox",
    "description": "# Introduction                                                           \nIt is **specific API** of BleBox devices with **API type:** *switchBox* <br><br> **Please check** **API type** and **API level** (version) before use, <br> **if you don't see the expected field** in response from a real device then **hardware version do not support this feature**.",
    "version": "20200831",
    "x-logo": {
      "url": "https://static.blebox.eu/technical/return_to_technical.png",
      "altText": "BleBox Technical",
      "href": "https://technical.blebox.eu/"
    }
  },
  "x-tagGroups": [
    {
      "name": "Common wBox API",
      "tags": [
        "General",
        "Network"
      ]
    },
    {
      "name": "switchBox API",
      "tags": [
        "Control & State",
        "Control with GET",
        "Settings"
      ]
    }
  ],
  "servers": [
    {
      "url": "http://192.168.4.1",
      "description": "Controller's web server - connecting via device's WiFi AP"
    },
    {
      "url": "http://IP_in_local_network",
      "description": "Controller's web server - connecting via local network - please change IP"
    },
    {
      "url": "http://device.blebox",
      "description": "Controller's web server - connecting via local network - for own DNS resolving"
    }
  ],
  "paths": {
    "/info": {
      "get": {
        "tags": [
          "General"
        ],
        "summary": "Information about device",
        "description": "Returns **general information** about device",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "device": {
                      "description": "**General** information about device",
                      "type": "object",
                      "properties": {
                        "deviceName": {
                          "$ref": "#/components/responses/settingsState/content/application~1json/schema/properties/settings/properties/deviceName"
                        },
                        "product": {
                          "description": "Product name for informational purpose only - do not use it in any application logic",
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 32,
                          "example": "shutterBoxV2"
                        },
                        "type": {
                          "description": "**API type** of BleBox device - it indicate what **device-specific API** should be used",
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 32,
                          "example": "shutterBox"
                        },
                        "apiLevel": {
                          "description": "**API level** of BleBox device - it indicate what version of **common and device-specific API** should be used",
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 32,
                          "example": "20200831"
                        },
                        "hv": {
                          "description": "Hardware version for informational purpose only - do not use it in any application logic",
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 32,
                          "example": "9.1d"
                        },
                        "fv": {
                          "description": "Firmware version for informational purpose only - do not use it in any application logic",
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 32,
                          "example": "0.987"
                        },
                        "id": {
                          "description": "Unique identification number of BleBox device",
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 32,
                          "example": "g650e32d2217"
                        },
                        "ip": {
                          "$ref": "#/paths/~1api~1wifi~1status/get/responses/200/content/application~1json/schema/properties/ip"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "deprecated": false
      }
    },
    "/api/device/state": {
      "get": {
        "tags": [
