        ],
        "summary": "Information about device",
        "description": "Returns **general information** about device <br><br>**It is deprecated** -> look at:",
        "responses": {
          "200": {
            "$ref": "#/paths/~1info/get/responses/200"
          }
        },
        "externalDocs": {
          "url": "#tag/General/paths/~1info/get",
          "description": "Information about device - /info"
