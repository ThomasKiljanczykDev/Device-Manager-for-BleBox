    "/api/device/uptime": {
      "get": {
        "tags": [
          "General"
        ],
        "summary": "Device upTime",
        "description": "Returns information about **number of seconds from boot**",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "upTimeS": {
                      "description": "Number of **seconds** since the device was turned on",
                      "type": "integer",
                      "format": "uint32_t",
                      "minimum": 0,
                      "maximum": 4294967295,
                      "example": 243269
                    }
                  }
                }
              }
            }
          }
        },
        "deprecated": false
      }
    },
    "/api/device/network": {
      "get": {
        "tags": [
          "Network"
        ],
        "summary": "Network information",
        "description": "Returns information about **internal WiFi AP** or about connected **local WiFi network**",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "description": "All information connected with network",
                  "type": "object",
                  "properties": {
                    "ssid": {
                      "$ref": "#/paths/~1api~1wifi~1status/get/responses/200/content/application~1json/schema/properties/ssid"
                    },
                    "bssid": {
                      "description": "BSSID of connected WiFi network. <br> **Empty string** indicates that **no WiFi network was found**",
                      "type": "string",
                      "minLength": 0,
                      "maxLength": 17,
                      "example": "70:4f:25:24:11:ae"
                    },
                    "ip": {
                      "$ref": "#/paths/~1api~1wifi~1status/get/responses/200/content/application~1json/schema/properties/ip"
                    },
                    "mac": {
                      "description": "MAC address of BleBox device. <br> This interface connect to Access Point (to local WiFi network)",
                      "type": "string",
                      "minLength": 17,
                      "maxLength": 17,
                      "example": "bb:50:ec:2d:22:17"
                    },
                    "station_status": {
                      "$ref": "#/paths/~1api~1wifi~1status/get/responses/200/content/application~1json/schema/properties/station_status"
                    },
                    "tunnel_status": {
                      "description": "<br>Status of **cloud connection** (remote access), where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**0**</td> <td>Waiting for stable WiFi connection</td> </tr> <tr> <td>**1**</td> <td>Connecting</td> </tr> <tr> <td>**2**</td> <td>Internet network is unreachable (DNS failed)</td> </tr> <tr> <td>**3**</td> <td>Internet network is unreachable (server not found)</td> </tr> <tr> <td>**4**</td> <td>Connection broken (connection was estabilished but it's broken now)</td> </tr> <tr> <td>**5**</td> <td>Connected</td> </tr> <tr> <td>**6**</td> <td>Disabled by user</td> </tr> </table>",
                      "type": "integer",
                      "format": "uint8_t",
                      "enum": [
                        0,
                        1,
                        2,
                        3,
                        4,
                        5,
                        6
                      ],
                      "example": 5
                    },
                    "apEnable": {
                      "$ref": "#/paths/~1api~1device~1set/post/requestBody/content/application~1json/schema/properties/network/properties/apEnable"
                    },
                    "apSSID": {
                      "$ref": "#/paths/~1api~1device~1set/post/requestBody/content/application~1json/schema/properties/network/properties/apSSID"
                    },
                    "apPasswd": {
                      "$ref": "#/paths/~1api~1device~1set/post/requestBody/content/application~1json/schema/properties/network/properties/apPasswd"
                    },
                    "channel": {
                      "description": "Channel of **internal** WiFi Access Point. **If device is connected to local WiFi** network then internal WiFi **channel is the same** as local WiFi Access Point's channel",
                      "type": "integer",
                      "format": "uint8_t",
                      "minimum": 1,
                      "maximum": 13,
                      "example": 7
                    }
                  }
                }
              }
            }
          }
        },
        "deprecated": false
      }
    },
    "/api/wifi/status": {
      "get": {
        "tags": [
          "Network"
        ],
        "summary": "Local WiFi Status",
        "description": "Returns information about **connected local WiFi network** and **if scanning is in progress** <br><br>**It is deprecated** -> look at:",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "scanning": {
                      "description": "<br>Parameter that show if **WiFi scanning is in progress**, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**false**</td> <td>disabled</td> </tr> <tr> <td>**true**</td> <td>enabled</td> </tr> </table>",
                      "type": "boolean",
                      "format": "string",
                      "enum": [
                        true,
                        false
                      ],
                      "example": false
                    },
                    "ssid": {
                      "description": "SSID of connected WiFi network. <br> **Empty string** indicates that **no WiFi network was selected**",
                      "type": "string",
                      "minLength": 0,
                      "maxLength": 32,
                      "example": "WiFi_Name"
                    },
                    "ip": {
                      "description": "IPv4 of BleBox device connected to local WiFi network. <br> **Empty string** indicates that **no WiFi network was connected**",
                      "type": "string",
                      "minLength": 0,
                      "maxLength": 15,
                      "example": "192.168.1.11"
                    },
                    "station_status": {
                      "description": "<br>Status of current **WiFi connection**, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**0**</td> <td>Not configured</td> </tr> <tr> <td>**1**</td> <td>Connecting</td> </tr> <tr> <td>**2**</td> <td>Wrong password</td> </tr> <tr> <td>**3**</td> <td>WiFi network not found</td> </tr> <tr> <td>**4**</td> <td>Communication with WiFi network failed</td> </tr> <tr> <td>**5**</td> <td>Connected</td> </tr> </table>",
                      "type": "integer",
                      "format": "uint8_t",
                      "enum": [
                        0,
                        1,
                        2,
                        3,
                        4,
                        5
                      ],
                      "example": 5
                    }
                  }
                }
              }
            }
          }
        },
        "externalDocs": {
          "url": "#tag/Common-wBox-API/paths/~1api~1device~1network/get",
          "description": "Network information - /api/device/network"
        },
        "deprecated": true
      }
    },
    "/api/device/set": {
      "post": {
        "tags": [
          "Network"
        ],
        "summary": "Set internal access Point's settings",
        "description": "**Allows to set** interal access Point's **ssid and password**. Allows also to **turn off internal AP**.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "network": {
                    "description": "**Internal** access Point's settings",
                    "type": "object",
                    "properties": {
                      "apEnable": {
                        "description": "<br>Parameter that show if **internal** WiFi Access Point is enabled, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**false**</td> <td>disabled</td> </tr> <tr> <td>**true**</td> <td>enabled</td> </tr> </table><br> If **false** - **apSSID** and **apPasswd** can be ignored.",
                        "type": "boolean",
                        "format": "string",
                        "enum": [
                          false,
                          true
                        ],
                        "example": true
                      },
                      "apSSID": {
                        "description": "SSID of **internal** WiFi access Point",
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 32,
                        "example": "shutterBox-g650e32d2217"
                      },
                      "apPasswd": {
                        "description": "Password of **internal** WiFi Access Point. <br> WPA2-PSK is used. <br>Empty string or 'null' indicates that internal AP is set to open mode (without password).",
                        "type": "string",
                        "pattern": "^$|^.{8,64}$",
                        "nullable": true,
                        "example": "my_secret_password"
                      }
                    }
                  }
                },
                "required": [
                  "network"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "device": {
                      "$ref": "#/paths/~1info/get/responses/200/content/application~1json/schema/properties/device"
                    },
                    "network": {
                      "$ref": "#/paths/~1api~1device~1network/get/responses/200/content/application~1json/schema"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        },
        "deprecated": false
      }
    },
    "/api/wifi/scan": {
      "get": {
        "tags": [
          "Network"
        ],
        "summary": "Perform WiFi scan and get results",
        "description": "**Perform WiFi scan** and **return list of found WiFi** networks. Return conflict if scanning is in progress",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ap": {
                      "description": "**List of** found **WiFi** networks",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "ssid": {
                            "description": "SSID (name) of found network",
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 32,
                            "example": "WiFi_Name"
                          },
                          "rssi": {
                            "description": "<br>**Signal strength** of found network, where:<br> <table> <tr> <td>From:</td> <td>To:</td> <td>Description:</td> </tr> <tr> <td>**-67**</td> <td>**0**</td> <td>Very good</td> </tr> <tr> <td>**-73**</td> <td>**-68**</td> <td>Good</td> </tr> <tr> <td>**-80**</td> <td>**-74**</td> <td>Poor</td> </tr> <tr> <td>**-127**</td> <td>**-81**</td> <td>Unstable/Unusable</td> </tr> </table>",
                            "type": "integer",
                            "format": "int8_t",
                            "minimum": -127,
                            "maximum": 0,
                            "example": -60
                          },
                          "enc": {
                            "description": "<br>**Encryption mode** of found network, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**0**</td> <td>Open network (without password) - unsafe, but can be used</td> </tr> <tr> <td>**1**</td> <td>WEP encryption - unsafe - can not be used</td> </tr> <tr> <td>**2**</td> <td>WPA encryption - unsafe - can not be used</td> </tr> <tr> <td>**3**</td> <td>WPA2 encryption - safe if properly configured - can be used (recomended)</td> </tr> <tr> <td>**4**</td> <td>WPA/WPA2 encryption - unsafe, but can be used as WPA2</td> </tr> </table>",
                            "type": "integer",
                            "format": "uint8_t",
                            "enum": [
                              0,
                              1,
                              2,
                              3,
                              4,
                              5
                            ],
                            "example": 3
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "ap": [
                    {
                      "ssid": "Funny_WiFi_Name",
                      "rssi": -60,
                      "enc": 3
                    },
                    {
                      "ssid": "Less_Funny_WiFi_Name",
                      "rssi": -75,
                      "enc": 4
                    },
                    {
                      "ssid": "Not_Funny_WiFi_Name",
                      "rssi": -90,
                      "enc": 0
                    }
                  ]
                }
              }
            }
          },
          "409": {
            "description": "Conflict"
          }
        },
        "deprecated": false
      }
    },
    "/api/wifi/connect": {
      "post": {
        "tags": [
          "Network"
        ],
        "summary": "Perform WiFi connect",
        "description": "Perform connect to local WiFi network",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ssid": {
                    "description": "SSID of WiFi network. <br> **Empty string** will disconnect from WiFi network",
                    "type": "string",
                    "minLength": 0,
                    "maxLength": 32,
                    "example": "WiFi_Name"
                  },
                  "pwd": {
                    "description": "Password to WiFi network. Empty string or 'null' indicates open mode (without password).",
                    "type": "string",
                    "minLength": 0,
                    "maxLength": 64,
                    "nullable": true,
                    "example": "my_secret_password"
                  }
                },
                "required": [
                  "ssid"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ssid": {
                      "$ref": "#/paths/~1api~1wifi~1status/get/responses/200/content/application~1json/schema/properties/ssid"
                    },
                    "station_status": {
                      "$ref": "#/paths/~1api~1wifi~1status/get/responses/200/content/application~1json/schema/properties/station_status"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/paths/~1api~1device~1set/post/responses/400"
          }
        }
      }
    },
    "/api/wifi/disconnect": {
      "post": {
