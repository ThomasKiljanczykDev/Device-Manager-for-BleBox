{
  "openapi": "3.0.3",
  "info": {
    "title": "API Type: buttonBox",
    "description": "# Introduction                                                           \nIt is **specific API** of BleBox devices with **API type:** *buttonBox* <br><br> **Please check** **API type** and **API level** (version) before use, <br> **if you don't see the expected field** in response from a real device then **hardware version do not support this feature**.",
    "version": "20200831",
    "x-logo": {
      "url": "https://static.blebox.eu/technical/return_to_technical.png",
      "altText": "BleBox Technical",
      "href": "https://technical.blebox.eu/"
    }
  },
  "x-tagGroups": [
    {
      "name": "Common wBox API",
      "tags": [
        "General",
        "Network"
      ]
    },
    {
      "name": "buttonBox API",
      "tags": [
        "Control & State",
