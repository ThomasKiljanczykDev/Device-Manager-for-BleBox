  "components": {
    "parameters": {
      "inputId": {
        "name": "inputId",
        "in": "path",
        "schema": {
          "$ref": "#/components/schemas/inputId"
        },
        "required": true
      },
      "triggerType": {
        "name": "triggerType",
        "in": "path",
        "schema": {
          "$ref": "#/components/schemas/triggerType"
        },
        "required": true
      }
    },
    "requestBodies": {
      "settingsSet": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "settings": {
                  "type": "object",
                  "properties": {
                    "deviceName": {
                      "$ref": "#/components/schemas/deviceName"
                    },
                    "tunnel": {
                      "$ref": "#/components/schemas/tunnel"
                    },
                    "statusLed": {
                      "$ref": "#/components/schemas/statusLed"
                    },
                    "buttonbox": {
                      "type": "object",
                      "properties": {
                        "uiType": {
                          "$ref": "#/components/schemas/uiType"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ap_set": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "network": {
                  "description": "**Internal** access Point's settings",
                  "type": "object",
                  "properties": {
                    "apEnable": {
                      "$ref": "#/components/schemas/apEnable"
                    },
                    "apSSID": {
                      "$ref": "#/components/schemas/apSSID"
                    },
                    "apPasswd": {
                      "$ref": "#/components/schemas/apPasswd"
                    }
                  }
                }
              },
              "required": [
                "network"
              ]
            }
          }
        }
      },
      "wifi_connect": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "ssid": {
                  "$ref": "#/components/schemas/ssid_connect"
                },
                "pwd": {
                  "$ref": "#/components/schemas/pwd"
                }
              },
              "required": [
                "ssid"
              ]
            }
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "OK"
      },
      "400": {
        "description": "Bad request"
      },
      "409": {
        "description": "Conflict"
      },
      "buttonboxState": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "inputs": {
                  "description": "List of all available inputs with corresponding states.",
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/inputStruct"
                  }
                }
              }
            }
          }
        }
      },
      "buttonboxExtendedState": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "inputs": {
                  "description": "List of all available inputs with corresponding states.",
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/inputStruct"
                  }
                },
                "buttonbox": {
                  "type": "object",
                  "properties": {
                    "uiType": {
                      "$ref": "#/components/schemas/uiType"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "settingsState": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "settings": {
                  "description": "Object with **specific** settings",
                  "type": "object",
                  "properties": {
                    "deviceName": {
                      "$ref": "#/components/schemas/deviceName"
                    },
                    "tunnel": {
                      "$ref": "#/components/schemas/tunnel"
                    },
                    "statusLed": {
                      "$ref": "#/components/schemas/statusLed"
                    },
                    "buttonbox": {
                      "properties": {
                        "uiType": {
                          "$ref": "#/components/schemas/uiType"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "device": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "device": {
                  "$ref": "#/components/schemas/device"
                }
              }
            }
          }
        }
      },
      "upTimeS": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "upTimeS": {
                  "$ref": "#/components/schemas/upTimeS"
                }
              }
            }
          }
        }
      },
      "network": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/network"
            }
          }
        }
      },
      "wifi_status": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "scanning": {
                  "$ref": "#/components/schemas/scanning"
                },
                "ssid": {
                  "$ref": "#/components/schemas/ssid"
                },
                "ip": {
                  "$ref": "#/components/schemas/ip"
                },
                "station_status": {
                  "$ref": "#/components/schemas/station_status"
                }
              }
            }
          }
        }
      },
      "ap_set": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "device": {
                  "$ref": "#/components/schemas/device"
                },
                "network": {
                  "$ref": "#/components/schemas/network"
                }
              }
            }
          }
        }
      },
      "wifi_scan": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "ap": {
                  "description": "**List of** found **WiFi** networks",
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ap_found"
                  }
                }
              }
            },
            "example": {
              "ap": [
                {
                  "ssid": "Funny_WiFi_Name",
                  "rssi": -60,
                  "enc": 3
                },
                {
                  "ssid": "Less_Funny_WiFi_Name",
                  "rssi": -75,
                  "enc": 4
                },
                {
                  "ssid": "Not_Funny_WiFi_Name",
                  "rssi": -90,
                  "enc": 0
                }
              ]
            }
          }
        }
      },
      "wifi_connect": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "ssid": {
                  "$ref": "#/components/schemas/ssid"
                },
                "station_status": {
                  "$ref": "#/components/schemas/station_status"
                }
              }
            }
          }
        }
      }
    },
    "schemas": {
      "inputStruct": {
        "description": "Description of selected input.",
        "type": "object",
        "properties": {
          "input": {
            "$ref": "#/components/schemas/inputId"
          },
          "state": {
            "$ref": "#/components/schemas/inputState"
          }
        },
        "required": [
          "input",
          "state"
        ]
      },
      "uiType": {
        "description": "Type of selected user interface (only information about the selected type, implementation should be provided on the GUI side), where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**0**</td> <td>Display controls for all triggers</td> </tr> <tr> <td>**1**</td> <td>Display controls for short and long click triggers only</td> </tr> </table>",
        "type": "integer",
        "format": "uint8_t",
        "enum": [
          0,
          1
        ],
        "example": 1
      },
      "triggerType": {
        "description": "Type of selected trigger, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**1**</td> <td>Short click</td> </tr> <tr> <td>**2**</td> <td>Long click</td> </tr> <tr> <td>**3**</td> <td>Falling edge (transition from high to low state on the selected input)</td> </tr> <tr> <td>**4**</td> <td>Rising edge (transition from low to high state on the selected input)</td> </tr> <tr> <td>**5**</td> <td>Any edge (transition from \"low to high state\" or \"high to low state\" on the selected input)</td> </tr> </table>",
        "type": "integer",
        "format": "uint8_t",
        "enum": [
          1,
          2,
          3,
          4,
          5
        ],
        "example": 1
      },
      "inputId": {
        "description": "Input ID. Numbered from 0. Maximum ID depending on the number of inputs available in the device (the available IDs are given in **inputs** array in the response of **Device state - /state**).",
        "type": "integer",
        "format": "uint8_t",
        "example": 0,
        "externalDocs": {
          "url": "#tag/Control-and-State/paths/~1state/get",
          "description": "Device state - /state"
        }
      },
      "inputState": {
        "description": "<br>Parameter that show **state of input**, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**0**</td> <td>Low</td> </tr> <tr> <td>**1**</td> <td>High</td> </tr> </table>",
        "type": "integer",
        "format": "uint8_t",
        "enum": [
          0,
          1
        ],
        "example": 1
      },
      "deviceName": {
        "description": "**Name** of BleBox device/controller",
        "type": "string",
        "minLength": 0,
        "maxLength": 31,
        "example": "My BleBox device name"
      },
      "product": {
        "description": "Product name for informational purpose only - do not use it in any application logic",
        "type": "string",
        "minLength": 1,
        "maxLength": 32,
        "example": "shutterBoxV2"
      },
      "apiType": {
        "description": "**API type** of BleBox device - it indicate what **device-specific API** should be used",
        "type": "string",
        "minLength": 1,
        "maxLength": 32,
        "example": "shutterBox"
      },
      "apiLevel": {
        "description": "**API level** of BleBox device - it indicate what version of **common and device-specific API** should be used",
        "type": "string",
        "minLength": 1,
        "maxLength": 32,
        "example": "20200831"
      },
      "hv": {
        "description": "Hardware version for informational purpose only - do not use it in any application logic",
        "type": "string",
        "minLength": 1,
        "maxLength": 32,
        "example": "9.1d"
      },
      "fv": {
        "description": "Firmware version for informational purpose only - do not use it in any application logic",
        "type": "string",
        "minLength": 1,
        "maxLength": 32,
        "example": "0.987"
      },
      "id": {
        "description": "Unique identification number of BleBox device",
        "type": "string",
        "minLength": 1,
        "maxLength": 32,
        "example": "g650e32d2217"
      },
      "ip": {
        "description": "IPv4 of BleBox device connected to local WiFi network. <br> **Empty string** indicates that **no WiFi network was connected**",
        "type": "string",
        "minLength": 0,
        "maxLength": 15,
        "example": "192.168.1.11"
      },
      "device": {
        "description": "**General** information about device",
        "type": "object",
        "properties": {
          "deviceName": {
            "$ref": "#/components/schemas/deviceName"
          },
          "product": {
            "$ref": "#/components/schemas/product"
          },
          "type": {
            "$ref": "#/components/schemas/apiType"
          },
          "apiLevel": {
            "$ref": "#/components/schemas/apiLevel"
          },
          "hv": {
            "$ref": "#/components/schemas/hv"
          },
          "fv": {
            "$ref": "#/components/schemas/fv"
          },
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "ip": {
            "$ref": "#/components/schemas/ip"
          }
        }
      },
      "upTimeS": {
        "description": "Number of **seconds** since the device was turned on",
        "type": "integer",
        "format": "uint32_t",
        "minimum": 0,
        "maximum": 4294967295,
        "example": 243269
      },
      "ssid": {
        "description": "SSID of connected WiFi network. <br> **Empty string** indicates that **no WiFi network was selected**",
        "type": "string",
        "minLength": 0,
        "maxLength": 32,
        "example": "WiFi_Name"
      },
      "bssid": {
        "description": "BSSID of connected WiFi network. <br> **Empty string** indicates that **no WiFi network was found**",
        "type": "string",
        "minLength": 0,
        "maxLength": 17,
        "example": "70:4f:25:24:11:ae"
      },
      "mac": {
        "description": "MAC address of BleBox device. <br> This interface connect to Access Point (to local WiFi network)",
        "type": "string",
        "minLength": 17,
        "maxLength": 17,
        "example": "bb:50:ec:2d:22:17"
      },
      "station_status": {
        "description": "<br>Status of current **WiFi connection**, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**0**</td> <td>Not configured</td> </tr> <tr> <td>**1**</td> <td>Connecting</td> </tr> <tr> <td>**2**</td> <td>Wrong password</td> </tr> <tr> <td>**3**</td> <td>WiFi network not found</td> </tr> <tr> <td>**4**</td> <td>Communication with WiFi network failed</td> </tr> <tr> <td>**5**</td> <td>Connected</td> </tr> </table>",
        "type": "integer",
        "format": "uint8_t",
        "enum": [
          0,
          1,
          2,
          3,
          4,
          5
        ],
        "example": 5
      },
      "tunnel_status": {
        "description": "<br>Status of **cloud connection** (remote access), where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**0**</td> <td>Waiting for stable WiFi connection</td> </tr> <tr> <td>**1**</td> <td>Connecting</td> </tr> <tr> <td>**2**</td> <td>Internet network is unreachable (DNS failed)</td> </tr> <tr> <td>**3**</td> <td>Internet network is unreachable (server not found)</td> </tr> <tr> <td>**4**</td> <td>Connection broken (connection was estabilished but it's broken now)</td> </tr> <tr> <td>**5**</td> <td>Connected</td> </tr> <tr> <td>**6**</td> <td>Disabled by user</td> </tr> </table>",
        "type": "integer",
        "format": "uint8_t",
        "enum": [
          0,
          1,
          2,
          3,
          4,
          5,
          6
        ],
        "example": 5
      },
      "apEnable": {
        "description": "<br>Parameter that show if **internal** WiFi Access Point is enabled, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**false**</td> <td>disabled</td> </tr> <tr> <td>**true**</td> <td>enabled</td> </tr> </table><br> If **false** - **apSSID** and **apPasswd** can be ignored.",
        "type": "boolean",
        "format": "string",
        "enum": [
          false,
          true
        ],
        "example": true
      },
      "apSSID": {
        "description": "SSID of **internal** WiFi access Point",
        "type": "string",
        "minLength": 1,
        "maxLength": 32,
        "example": "shutterBox-g650e32d2217"
      },
      "apPasswd": {
        "description": "Password of **internal** WiFi Access Point. <br> WPA2-PSK is used. <br>Empty string or 'null' indicates that internal AP is set to open mode (without password).",
        "type": "string",
        "pattern": "^$|^.{8,64}$",
        "nullable": true,
        "example": "my_secret_password"
      },
      "apChannel": {
        "description": "Channel of **internal** WiFi Access Point. **If device is connected to local WiFi** network then internal WiFi **channel is the same** as local WiFi Access Point's channel",
        "type": "integer",
        "format": "uint8_t",
        "minimum": 1,
        "maximum": 13,
        "example": 7
      },
      "network": {
        "description": "All information connected with network",
        "type": "object",
        "properties": {
          "ssid": {
            "$ref": "#/components/schemas/ssid"
          },
          "bssid": {
            "$ref": "#/components/schemas/bssid"
          },
          "ip": {
            "$ref": "#/components/schemas/ip"
          },
          "mac": {
            "$ref": "#/components/schemas/mac"
          },
          "station_status": {
            "$ref": "#/components/schemas/station_status"
          },
          "tunnel_status": {
            "$ref": "#/components/schemas/tunnel_status"
          },
          "apEnable": {
            "$ref": "#/components/schemas/apEnable"
          },
          "apSSID": {
            "$ref": "#/components/schemas/apSSID"
          },
          "apPasswd": {
            "$ref": "#/components/schemas/apPasswd"
          },
          "channel": {
            "$ref": "#/components/schemas/apChannel"
          }
        }
      },
      "scanning": {
        "description": "<br>Parameter that show if **WiFi scanning is in progress**, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**false**</td> <td>disabled</td> </tr> <tr> <td>**true**</td> <td>enabled</td> </tr> </table>",
        "type": "boolean",
        "format": "string",
        "enum": [
          true,
          false
        ],
        "example": false
      },
      "ssid_scan": {
        "description": "SSID (name) of found network",
        "type": "string",
        "minLength": 1,
        "maxLength": 32,
        "example": "WiFi_Name"
      },
      "rssi": {
        "description": "<br>**Signal strength** of found network, where:<br> <table> <tr> <td>From:</td> <td>To:</td> <td>Description:</td> </tr> <tr> <td>**-67**</td> <td>**0**</td> <td>Very good</td> </tr> <tr> <td>**-73**</td> <td>**-68**</td> <td>Good</td> </tr> <tr> <td>**-80**</td> <td>**-74**</td> <td>Poor</td> </tr> <tr> <td>**-127**</td> <td>**-81**</td> <td>Unstable/Unusable</td> </tr> </table>",
        "type": "integer",
        "format": "int8_t",
        "minimum": -127,
        "maximum": 0,
        "example": -60
      },
      "encryption": {
        "description": "<br>**Encryption mode** of found network, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**0**</td> <td>Open network (without password) - unsafe, but can be used</td> </tr> <tr> <td>**1**</td> <td>WEP encryption - unsafe - can not be used</td> </tr> <tr> <td>**2**</td> <td>WPA encryption - unsafe - can not be used</td> </tr> <tr> <td>**3**</td> <td>WPA2 encryption - safe if properly configured - can be used (recomended)</td> </tr> <tr> <td>**4**</td> <td>WPA/WPA2 encryption - unsafe, but can be used as WPA2</td> </tr> </table>",
        "type": "integer",
        "format": "uint8_t",
        "enum": [
          0,
          1,
          2,
          3,
          4,
          5
        ],
        "example": 3
      },
      "ap_found": {
        "type": "object",
        "properties": {
          "ssid": {
            "$ref": "#/components/schemas/ssid_scan"
          },
          "rssi": {
            "$ref": "#/components/schemas/rssi"
          },
          "enc": {
            "$ref": "#/components/schemas/encryption"
          }
        }
      },
      "ssid_connect": {
        "description": "SSID of WiFi network. <br> **Empty string** will disconnect from WiFi network",
        "type": "string",
        "minLength": 0,
        "maxLength": 32,
        "example": "WiFi_Name"
      },
      "pwd": {
        "description": "Password to WiFi network. Empty string or 'null' indicates open mode (without password).",
        "type": "string",
        "minLength": 0,
        "maxLength": 64,
        "nullable": true,
        "example": "my_secret_password"
      },
      "bool_field_enabled": {
        "description": "<br>Allow to **disable or enable function**, where:<br> <table> <tr> <td>Enum:</td> <td>Description:</td> </tr> <tr> <td>**0**</td> <td>disabled</td> </tr> <tr> <td>**1**</td> <td>enabled</td> </tr> </table>",
        "type": "integer",
        "format": "uint8_t",
        "enum": [
          0,
          1
        ],
        "example": 1
      },
      "tunnel": {
        "description": "Allows to **enable or disable** connection with **the BleBox's cloud** and decide whether events generated by this device should be log to **the BleBox's cloud** (necessary for push notifications), the user can view the event log through the wBox application.",
        "type": "object",
        "properties": {
          "enabled": {
            "$ref": "#/components/schemas/bool_field_enabled"
          },
          "logEnabled": {
            "$ref": "#/components/schemas/bool_field_enabled"
          }
        }
      },
      "statusLed": {
        "description": "Allows to **enable** or **disable** extended status notification using built in **LED**",
        "type": "object",
        "properties": {
          "enabled": {
            "$ref": "#/components/schemas/bool_field_enabled"
          }
        }
      }
    }
  }
