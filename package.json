{
  "name": "blebox-device-manager",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "yarn codegen && concurrently -k -n web,companion -c blue,magenta \"yarn workspace web dev\" \"yarn workspace companion dev\"",
    "codegen": "yarn workspace companion gen:spec && node scripts/codegen.mjs",
    "lint": "yarn workspaces foreach -A run lint",
    "test": "yarn workspaces foreach -A run test",
    "typecheck": "yarn workspaces foreach -A run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@openapitools/openapi-generator-cli": "^2.15.3",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
